{
  "name": "radio-platform-backend",
  "version": "1.0.0",
  "packageManager": "bun@1.3.8",
  "description": "Backend API for Global Radio & Podcast Platform",
  "main": "dist/main.js",
  "scripts": {
    "build": "bunx --bun nest build",
    "start": "bun dist/main.js",
    "dev": "nodemon --watch src --exec ts-node src/main.ts",
    "migrate:run": "bun run --bun run-migrations.ts",
    "migration:generate": "bunx typeorm migration:generate -d ./data-source.ts",
    "lint": "echo 'Linting not configured yet'",
    "test": "echo 'Tests not configured yet'"
  },
  "keywords": [
    "radio",
    "podcast",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.15.2",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/xml2js": "^0.4.14",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
